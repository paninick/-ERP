# 生产环境变量模板
# 复制此文件为 .env.production，填入真实值，部署到服务器
# 永远不要将 .env.production 提交到 git
#
# 推荐加载方式:
#   systemd:  EnvironmentFile=/etc/ruoyi/erp.env
#   docker:   --env-file=.env.production
#   脚本:     set -a; source .env.production; set +a; java -jar ...

# ========== JWT ==========
# JWT 密钥（64位十六进制，固定不变，重启后 token 仍有效）
# 生成: openssl rand -hex 32
JWT_SECRET=替换为随机64位十六进制字符串

# ========== 数据库（MySQL）==========
# 完整 JDBC URL（包含 host/port/库名/参数）
DB_URL=jdbc:mysql://替换为内网IP:3306/ry_vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
# 应用专用账号（禁用 root，最小权限：SELECT/INSERT/UPDATE/DELETE/EXECUTE + DDL）
DB_USERNAME=替换为应用账号
DB_PASSWORD=替换为强密码

# ========== Redis ==========
# Redis 服务器地址与端口
REDIS_HOST=替换为内网IP或localhost
REDIS_PORT=6379
# Redis 密码（本地开发可留空）
REDIS_PASSWORD=替换为强密码

# ========== 文件上传路径 ==========
# Linux 服务器必须覆盖默认 Windows 路径（默认 D:/erp/RuoYi-Vue/uploadPath 仅本地开发可用）
# 目录需提前创建并对应用进程赋写权限
UPLOAD_PATH=/home/ruoyi/uploadPath

# ========== Druid 监控控制台 ==========
DRUID_USERNAME=替换为用户名
DRUID_PASSWORD=替换为强密码
# 白名单禁止 0.0.0.0；仅配置内网 IP 段
DRUID_ALLOW=127.0.0.1,192.168.1.0/24
