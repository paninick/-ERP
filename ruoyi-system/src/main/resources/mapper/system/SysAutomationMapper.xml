<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysAutomationMapper">

    <resultMap type="SysAutomation" id="SysAutomationResult">
        <id property="taskId" column="task_id" />
        <result property="taskName" column="task_name" />
        <result property="taskType" column="task_type" />
        <result property="cronExpression" column="cron_expression" />
        <result property="description" column="description" />
        <result property="status" column="status" />
        <result property="executeTime" column="execute_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectSysAutomationVo">
        select task_id, task_name, task_type, cron_expression, description, status,
               execute_time, create_by, create_time, update_by, update_time
        from sys_automation
    </sql>

    <select id="selectSysAutomationList" parameterType="SysAutomation" resultMap="SysAutomationResult">
        <include refid="selectSysAutomationVo"/>
        <where>
            <if test="taskName != null and taskName != ''">and task_name like concat('%', #{taskName}, '%')</if>
            <if test="taskType != null and taskType != ''">and task_type = #{taskType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by task_id desc
    </select>

    <select id="selectSysAutomationById" parameterType="Long" resultMap="SysAutomationResult">
        <include refid="selectSysAutomationVo"/>
        where task_id = #{taskId}
    </select>

    <insert id="insertSysAutomation" parameterType="SysAutomation" useGeneratedKeys="true" keyProperty="taskId">
        insert into sys_automation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="taskType != null and taskType != ''">task_type,</if>
            <if test="cronExpression != null">cron_expression,</if>
            <if test="description != null">description,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="executeTime != null">execute_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="taskType != null and taskType != ''">#{taskType},</if>
            <if test="cronExpression != null">#{cronExpression},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="executeTime != null">#{executeTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateSysAutomation" parameterType="SysAutomation">
        update sys_automation
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="taskType != null and taskType != ''">task_type = #{taskType},</if>
            <if test="cronExpression != null">cron_expression = #{cronExpression},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="executeTime != null">execute_time = #{executeTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteSysAutomationById" parameterType="Long">
        delete from sys_automation where task_id = #{taskId}
    </delete>

    <delete id="deleteSysAutomationByIds" parameterType="Long">
        delete from sys_automation where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

</mapper>
