            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateStockOutItem" parameterType="StockOutItem">
        update t_erp_stock_out_item
        <trim prefix="SET" suffixOverrides=",">
            <if test="outId != null">out_id = #{outId},</if>
            <if test="sn != null">sn = #{sn},</if>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialType != null">material_type = #{materialType},</if>
            <if test="materialNo != null and materialNo != ''">material_no = #{materialNo},</if>
            <if test="name != null">name = #{name},</if>
            <if test="count != null">count = #{count},</if>
            <if test="composition != null">composition = #{composition},</if>
            <if test="width != null">width = #{width},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="substance != null">substance = #{substance},</if>
            <if test="size != null">size = #{size},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="warehouseAreaId != null">warehouse_area_id = #{warehouseAreaId},</if>
            <if test="warehouseLocationId != null">warehouse_location_id = #{warehouseLocationId},</if>
            <if test="saveLocation != null">save_location = #{saveLocation},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStockOutItemById" parameterType="Long">
        delete from t_erp_stock_out_item where id = #{id}
    </delete>

    <delete id="deleteStockOutItemByIds" parameterType="String">
        delete from t_erp_stock_out_item where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertStockOutItemBatch" parameterType="java.util.List">

        REPLACE INTO t_erp_stock_out_item
        (id,out_id,sn,material_id,material_type,material_no,name,count,composition,width,weight,substance,size,warehouse_id,warehouse_area_id,warehouse_location_id,save_location,create_by,create_time,update_by,update_time,)
        VALUES
        <foreach collection="list" item="item" index="index" separator=",">

            (#{item.id},#{item.outId},#{item.sn},#{item.materialId},#{item.materialType},#{item.materialNo},#{item.name},#{item.count},#{item.composition},#{item.width},#{item.weight},#{item.substance},#{item.size},#{item.warehouseId},#{item.warehouseAreaId},#{item.warehouseLocationId},#{item.saveLocation},#{item.createBy},#{item.createTime},#{item.updateBy},#{item.updateTime},)

        </foreach>
    </insert>

    <select id="selectStockOutItemByOutId" parameterType="Long" resultMap="StockOutItemResult">
        <include refid="selectStockOutItemVo"/>
        where a.out_id = #{outId}
    </select>

</mapper>
