        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectStockOutItemVo">
        select a.id, a.out_id, a.sn, a.material_id, a.material_type, a.material_no, a.name, a.count, a.composition, a.width, a.weight, a.substance, a.size, a.warehouse_id, a.warehouse_area_id, a.warehouse_location_id, a.save_location, a.create_by, a.create_time, a.update_by, a.update_time
        from t_erp_stock_out_item a
    </sql>

    <select id="selectStockOutItemList" parameterType="StockOutItem" resultMap="StockOutItemResult">
        <include refid="selectStockOutItemVo"/>
        <where>
            <if test="sn != null  and sn != ''"> and a.sn = #{sn}</if>
            <if test="materialType != null  and materialType != ''"> and a.material_type = #{materialType}</if>
            <if test="materialNo != null  and materialNo != ''"> and a.material_no = #{materialNo}</if>
            <if test="name != null  and name != ''"> and a.name like concat('%', #{name}, '%')</if>
            <if test="warehouseId != null "> and a.warehouse_id = #{warehouseId}</if>
            <if test="warehouseAreaId != null "> and a.warehouse_area_id = #{warehouseAreaId}</if>
            <if test="warehouseLocationId != null "> and a.warehouse_location_id = #{warehouseLocationId}</if>
        </where>
    </select>

    <select id="selectStockOutItemById" parameterType="Long" resultMap="StockOutItemResult">
        <include refid="selectStockOutItemVo"/>
        where a.id = #{id}
    </select>

    <insert id="insertStockOutItem" parameterType="StockOutItem" useGeneratedKeys="true" keyProperty="id">
        insert into t_erp_stock_out_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="outId != null">out_id,</if>
            <if test="sn != null">sn,</if>
            <if test="materialId != null">material_id,</if>
            <if test="materialType != null">material_type,</if>
            <if test="materialNo != null and materialNo != ''">material_no,</if>
            <if test="name != null">name,</if>
            <if test="count != null">count,</if>
            <if test="composition != null">composition,</if>
            <if test="width != null">width,</if>
            <if test="weight != null">weight,</if>
            <if test="substance != null">substance,</if>
            <if test="size != null">size,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="warehouseAreaId != null">warehouse_area_id,</if>
            <if test="warehouseLocationId != null">warehouse_location_id,</if>
            <if test="saveLocation != null">save_location,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="outId != null">#{outId},</if>
            <if test="sn != null">#{sn},</if>
            <if test="materialId != null">#{materialId},</if>
            <if test="materialType != null">#{materialType},</if>
            <if test="materialNo != null and materialNo != ''">#{materialNo},</if>
            <if test="name != null">#{name},</if>
