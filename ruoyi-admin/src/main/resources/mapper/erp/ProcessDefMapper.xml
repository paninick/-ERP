<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.ProcessDefMapper">

    <resultMap type="ProcessDef" id="ProcessDefResult">
        <result property="id"    column="id"    />
        <result property="processCode"    column="process_no"    />
        <result property="processName"    column="process_name"    />
        <result property="processType"    column="process_type"    />
        <result property="defaultPrice"    column="unit_price"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"    column="status"    />
        <result property="isSpliceProcess"        column="is_splice_process"       />
        <result property="shrinkageBaseline"      column="shrinkage_baseline"      />
        <result property="elasticityCompensation" column="elasticity_compensation" />
        <result property="seamWidth"              column="seam_width"              />
        <result property="spliceDirection"        column="splice_direction"        />
        <result property="fabricCompatibility"    column="fabric_compatibility"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectProcessDefVo">
        select a.id, a.process_no, a.process_name, a.process_type, a.unit_price, a.sort_order, a.status,
               a.is_splice_process, a.shrinkage_baseline, a.elasticity_compensation, a.seam_width, a.splice_direction, a.fabric_compatibility,
               a.remark, a.create_by, a.create_time, a.update_by, a.update_time
        from t_erp_process_def a
    </sql>

    <select id="selectProcessDefList" parameterType="ProcessDef" resultMap="ProcessDefResult">
        <include refid="selectProcessDefVo"/>
        <where>
            <if test="processCode != null  and processCode != ''"> and a.process_no = #{processCode}</if>
            <if test="processName != null  and processName != ''"> and a.process_name like concat('%', #{processName}, '%')</if>
            <if test="processType != null  and processType != ''"> and a.process_type = #{processType}</if>
            <if test="status != null  and status != ''"> and a.status = #{status}</if>
        </where>
        order by a.sort_order asc
    </select>

    <select id="selectProcessDefById" parameterType="Long" resultMap="ProcessDefResult">
        <include refid="selectProcessDefVo"/>
        where a.id = #{id}
    </select>

    <select id="selectProcessDefByCode" parameterType="String" resultMap="ProcessDefResult">
        <include refid="selectProcessDefVo"/>
        where a.process_no = #{processCode}
    </select>

    <insert id="insertProcessDef" parameterType="ProcessDef" useGeneratedKeys="true" keyProperty="id">
        insert into t_erp_process_def
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="processCode != null">process_no,</if>
            <if test="processName != null">process_name,</if>
            <if test="processType != null">process_type,</if>
            <if test="defaultPrice != null">unit_price,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="isSpliceProcess != null">is_splice_process,</if>
            <if test="shrinkageBaseline != null">shrinkage_baseline,</if>
            <if test="elasticityCompensation != null">elasticity_compensation,</if>
            <if test="seamWidth != null">seam_width,</if>
            <if test="spliceDirection != null">splice_direction,</if>
            <if test="fabricCompatibility != null">fabric_compatibility,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="processCode != null">#{processCode},</if>
            <if test="processName != null">#{processName},</if>
            <if test="processType != null">#{processType},</if>
            <if test="defaultPrice != null">#{defaultPrice},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="isSpliceProcess != null">#{isSpliceProcess},</if>
            <if test="shrinkageBaseline != null">#{shrinkageBaseline},</if>
            <if test="elasticityCompensation != null">#{elasticityCompensation},</if>
            <if test="seamWidth != null">#{seamWidth},</if>
            <if test="spliceDirection != null">#{spliceDirection},</if>
            <if test="fabricCompatibility != null">#{fabricCompatibility},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateProcessDef" parameterType="ProcessDef">
        update t_erp_process_def
        <trim prefix="SET" suffixOverrides=",">
            <if test="processCode != null">process_no = #{processCode},</if>
            <if test="processName != null">process_name = #{processName},</if>
            <if test="processType != null">process_type = #{processType},</if>
            <if test="defaultPrice != null">unit_price = #{defaultPrice},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isSpliceProcess != null">is_splice_process = #{isSpliceProcess},</if>
            <if test="shrinkageBaseline != null">shrinkage_baseline = #{shrinkageBaseline},</if>
            <if test="elasticityCompensation != null">elasticity_compensation = #{elasticityCompensation},</if>
            <if test="seamWidth != null">seam_width = #{seamWidth},</if>
            <if test="spliceDirection != null">splice_direction = #{spliceDirection},</if>
            <if test="fabricCompatibility != null">fabric_compatibility = #{fabricCompatibility},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteProcessDefById" parameterType="Long">
        delete from t_erp_process_def where id = #{id}
    </delete>

    <delete id="deleteProcessDefByIds" parameterType="Long">
        delete from t_erp_process_def where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
