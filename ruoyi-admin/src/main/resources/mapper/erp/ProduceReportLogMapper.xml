    <select id="selectProduceReportLogById" parameterType="Long" resultMap="BaseResultMap">
        SELECT l.*, p.process_name, j.job_no
        FROM t_erp_produce_report_log l
        LEFT JOIN t_erp_process_def p ON l.process_id = p.id
        LEFT JOIN t_erp_produce_job j ON l.job_id = j.id
        WHERE l.id = #{id} AND l.del_flag = '0'
    </select>

    <select id="selectProduceReportLogList" parameterType="com.ruoyi.erp.domain.ProduceReportLog" resultMap="BaseResultMap">
        SELECT l.*, p.process_name, j.job_no
        FROM t_erp_produce_report_log l
        LEFT JOIN t_erp_process_def p ON l.process_id = p.id
        LEFT JOIN t_erp_produce_job j ON l.job_id = j.id
        <where>
            l.del_flag = '0'
            <if test="jobId != null">AND l.job_id = #{jobId}</if>
            <if test="jobProcessId != null">AND l.job_process_id = #{jobProcessId}</if>
            <if test="processId != null">AND l.process_id = #{processId}</if>
            <if test="employeeId != null">AND l.employee_id = #{employeeId}</if>
            <if test="reportType != null and reportType != ''">AND l.report_type = #{reportType}</if>
            <if test="reportSource != null and reportSource != ''">AND l.report_source = #{reportSource}</if>
            <if test="batchNo != null and batchNo != ''">AND l.batch_no = #{batchNo}</if>
            <if test="isOutsourced != null and isOutsourced != ''">AND l.is_outsourced = #{isOutsourced}</if>
            <if test="vendorId != null">AND l.vendor_id = #{vendorId}</if>
            <if test="validationStatus != null and validationStatus != ''">AND l.validation_status = #{validationStatus}</if>
        </where>
        ORDER BY l.event_time DESC, l.id DESC
    </select>

