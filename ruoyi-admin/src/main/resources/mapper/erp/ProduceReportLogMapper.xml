    <select id="sumReportQtyByJobProcessId" parameterType="Long" resultType="java.lang.Integer">
        SELECT COALESCE(SUM(report_qty), 0)
        FROM t_erp_produce_report_log
        WHERE job_process_id = #{jobProcessId}
          AND del_flag = '0'
          AND validation_status = 'PASS'
