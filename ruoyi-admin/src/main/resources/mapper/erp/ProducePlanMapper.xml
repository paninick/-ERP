    <select id="countOnTimeCompleted" resultType="int">
        SELECT COUNT(*) FROM t_erp_produce_plan
        WHERE complete_date &lt;= due_date AND plan_status IN ('5','6','7','9')
    </select>

    <!-- 查询甘特图任务列表 -->
    <select id="selectGanttTasks" resultType="com.ruoyi.erp.domain.vo.GanttTaskVO">
        SELECT
            id as id,
            plan_no as name,
            start_date as start,
            due_date as end,
            CASE
                WHEN plan_status = '1' THEN 0
                WHEN plan_status = '2' THEN 10
                WHEN plan_status = '3' THEN 30
                WHEN plan_status = '4' THEN 60
                WHEN plan_status = '5' THEN 80
                WHEN plan_status = '9' THEN 100
                ELSE 0
            END as progress,
            sales_name as owner,
            plan_status as status,
            customer_name as customerName,
            style_category as styleCategory
        FROM t_erp_produce_plan
        WHERE plan_status NOT IN ('10')
        ORDER BY start_date ASC
    </select>

    <!-- 更新计划日期 -->
    <update id="updatePlanDates">
        UPDATE t_erp_produce_plan
        SET start_date = #{startDate}, due_date = #{dueDate}
        WHERE id = #{id}
    </update>

</mapper>
