    </select>

    <!-- 按状态统计 -->
    <select id="countByStatus" resultType="int" parameterType="string">
        SELECT COUNT(*) FROM t_erp_produce_plan WHERE plan_status = #{status}
    </select>

    <!-- 按状态列表统计 -->
    <select id="countByStatusIn" resultType="int">
        SELECT COUNT(*) FROM t_erp_produce_plan WHERE plan_status IN
        <foreach item="status" collection="list" open="(" separator="," close=")">
            #{status}
        </foreach>
    </select>

    <!-- 统计指定日期完成 -->
    <select id="countCompletedByDate" resultType="int" parameterType="date">
        SELECT COUNT(*) FROM t_erp_produce_plan
        WHERE complete_date &gt;= #{date} AND complete_date &lt; DATE_ADD(#{date}, INTERVAL 1 DAY)
        AND plan_status IN ('5','6','7','9')
    </select>

    <!-- 统计时间段完成 -->
    <select id="countCompletedBetween" resultType="int">
        SELECT COUNT(*) FROM t_erp_produce_plan
        WHERE complete_date &gt;= #{start} AND complete_date &lt;= #{end}
        AND plan_status IN ('5','6','7','9')
    </select>

    <!-- 统计时间段内完成总数 -->
    <select id="countCompletedInPeriod" resultType="int">
        SELECT COUNT(*) FROM t_erp_produce_plan
        <where>
            <if test="start != null">AND complete_date &gt;= #{start}</if>
            <if test="end != null">AND complete_date &lt;= #{end}</if>
        </where>
        AND plan_status IN ('5','6','7','9')
    </select>

