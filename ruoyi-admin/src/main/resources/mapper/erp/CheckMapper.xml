            </if>
            <if test="quantity != null">
                quantity,
            </if>
            <if test="checkDescription != null and checkDescription != ''">
                check_description,
            </if>
            <if test="checkResult != null and checkResult != ''">
                check_result,
            </if>
            <if test="status != null and status != ''">
