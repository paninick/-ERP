<mapper namespace="com.ruoyi.erp.mapper.CheckMapper">
    <resultMap type="Check" id="CheckResult">
        <id property="checkId" column="check_id" />
        <result property="checkNo" column="check_no" />
        <result property="sampleNo" column="sample_no" />
        <result property="techNo" column="tech_no" />
