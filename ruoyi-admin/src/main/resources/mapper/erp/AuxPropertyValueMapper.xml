<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.AuxPropertyValueMapper">

    <resultMap type="com.ruoyi.erp.domain.AuxPropertyValue" id="AuxPropertyValueResult">
        <id property="id" column="id"/>
        <result property="auxType" column="aux_type"/>
        <result property="valueCode" column="value_code"/>
        <result property="valueName" column="value_name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectAuxPropertyValueVo">
        select id, aux_type, value_code, value_name, sort_order, status,
               create_by, create_time, update_by, update_time, remark
        from t_erp_aux_property_value
        where status = '0'
    </sql>

    <select id="selectAuxPropertyValueById" parameterType="Long" resultMap="AuxPropertyValueResult">
        <include refid="selectAuxPropertyValueVo"/>
        and id = #{id}
    </select>

    <select id="selectAuxPropertyValueByIds" resultMap="AuxPropertyValueResult">
        <include refid="selectAuxPropertyValueVo"/>
        and id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        order by sort_order asc
    </select>

    <select id="selectAuxPropertyValueList" parameterType="com.ruoyi.erp.domain.AuxPropertyValue" resultMap="AuxPropertyValueResult">
        <include refid="selectAuxPropertyValueVo"/>
        <if test="auxType != null">
            and aux_type = #{auxType}
        </if>
        <if test="valueCode != null and valueCode != ''">
            and value_code like concat('%', #{valueCode}, '%')
        </if>
        <if test="valueName != null and valueName != ''">
            and value_name like concat('%', #{valueName}, '%')
        </if>
        order by aux_type asc, sort_order asc
    </select>

    <insert id="insertAuxPropertyValue" parameterType="com.ruoyi.erp.domain.AuxPropertyValue" useGeneratedKeys="true" keyProperty="id">
        insert into t_erp_aux_property_value (
            aux_type, value_code, value_name, sort_order, status,
            create_by, create_time, update_by, update_time, remark
        ) values (
            #{auxType}, #{valueCode}, #{valueName}, #{sortOrder}, #{status},
            #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{remark}
        )
    </insert>

    <update id="updateAuxPropertyValue" parameterType="com.ruoyi.erp.domain.AuxPropertyValue">
        update t_erp_aux_property_value set
            <if test="auxType != null">aux_type = #{auxType},</if>
            <if test="valueCode != null">value_code = #{valueCode},</if>
            <if test="valueName != null">value_name = #{valueName},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            id = id
        where id = #{id}
    </update>

    <delete id="deleteAuxPropertyValueById" parameterType="Long">
        delete from t_erp_aux_property_value where id = #{id}
    </delete>

    <delete id="deleteAuxPropertyValueByIds">
        delete from t_erp_aux_property_value where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
