    </insert>

    <insert id="insertAuxiliaryMaterialBatchSafe" parameterType="java.util.List">
        INSERT IGNORE INTO t_erp_auxiliary_material
        (auxiliary_material_type,auxiliary_material_no,supply_method,supplier_id,name,substance,size,unit,picture_url,create_by,create_time,update_by,update_time,remark)
        VALUES
        <foreach collection="list" item="item" index="index" separator=",">
