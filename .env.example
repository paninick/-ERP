# .env.example — 复制为 .env 并填写真实生产值
# 此文件安全入库（无敏感值），.env 本身已在 .gitignore 中排除

# ── MySQL (阿里云 RDS for MySQL 5.7 高可用版) ──
DB_URL=jdbc:mysql://<RDS内网地址>:3306/ry_vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=erp_app
DB_PASSWORD=<强密码≥16位>

# ── Redis (阿里云 Redis Tair 标准版 6.0) ──
REDIS_HOST=<Tair内网地址>
REDIS_PORT=6379
REDIS_PASSWORD=<Redis密码>

# ── JWT 密钥（64位十六进制，`openssl rand -hex 32` 生成）──
JWT_SECRET=<随机64位hex>

# ── Druid 监控控制台 ──
DRUID_USERNAME=erp_druid
DRUID_PASSWORD=<强密码>
DRUID_ALLOW=<内网IP段,如 172.16.0.0/12>
