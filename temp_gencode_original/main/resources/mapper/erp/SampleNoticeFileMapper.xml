<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.SampleNoticeFileMapper">

    <resultMap type="SampleNoticeFile" id="SampleNoticeFileResult">
        <result property="id"    column="id"    />
        <result property="noticeId"    column="notice_id"    />
        <result property="fileName"    column="file_name"    />
        <result property="fileUrl"    column="file_url"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectSampleNoticeFileVo">
        select a.id, a.notice_id, a.file_name, a.file_url, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from t_erp_sample_notice_file a
    </sql>

    <select id="selectSampleNoticeFileList" parameterType="SampleNoticeFile" resultMap="SampleNoticeFileResult">
        <include refid="selectSampleNoticeFileVo"/>
        <where>
            <if test="noticeId != null "> and a.notice_id = #{noticeId}</if>
            <if test="fileName != null  and fileName != ''"> and a.file_name like concat('%', #{fileName}, '%')</if>
            <if test="fileUrl != null  and fileUrl != ''"> and a.file_url = #{fileUrl}</if>
        </where>
    </select>

    <select id="selectSampleNoticeFileById" parameterType="Long" resultMap="SampleNoticeFileResult">
        <include refid="selectSampleNoticeFileVo"/>
        where a.id = #{id}
    </select>

    <insert id="insertSampleNoticeFile" parameterType="SampleNoticeFile" useGeneratedKeys="true" keyProperty="id">
        insert into t_erp_sample_notice_file
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="noticeId != null">notice_id,</if>
            <if test="fileName != null">file_name,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="noticeId != null">#{noticeId},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateSampleNoticeFile" parameterType="SampleNoticeFile">
        update t_erp_sample_notice_file
        <trim prefix="SET" suffixOverrides=",">
            <if test="noticeId != null">notice_id = #{noticeId},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSampleNoticeFileById" parameterType="Long">
        delete from t_erp_sample_notice_file where id = #{id}
    </delete>

    <delete id="deleteSampleNoticeFileByIds" parameterType="String">
        delete from t_erp_sample_notice_file where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertSampleNoticeFileBatch" parameterType="java.util.List">

        REPLACE INTO t_erp_sample_notice_file
        (id,notice_id,file_name,file_url,create_by,create_time,update_by,update_time,remark,)
        VALUES
        <foreach collection="list" item="item" index="index" separator=",">

            (#{item.id},#{item.noticeId},#{item.fileName},#{item.fileUrl},#{item.createBy},#{item.createTime},#{item.updateBy},#{item.updateTime},#{item.remark},)

        </foreach>
    </insert>

</mapper>
